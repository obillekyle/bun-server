{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": ["*.ts", "**/*.ts"],
  "exclude": [
    ".server/**/*.ts",
    ".database/**/*.ts",
    ".dashboard/**/*.ts",
    "server.config.ts",
    "api/**/*.ts"
  ],
  "files": [
    ".server/client/globals.d.ts",
    ".server/client/livereload.ts",
    ".server/client/utils.ts",
    ".dashboard/dashboard.ts"
  ]
}
