{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": ["*.ts", "**/*.ts", "jsx.tsx"],
  "exclude": [
    ".server/**/*.ts",
    ".database/**/*.ts",
    "server.config.ts",
    "api/**/*.ts",
    "**/*.tsx"
  ],
  "files": [
    ".server/client.d.ts",
    ".server/client-livereload.ts",
    ".server/client-utils.ts"
  ]
}
