{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@client/utils": [
        "./.server/client/utils"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    ".server/client/**/*.ts",
    ".server/plugins/**/client/**/*.ts"
  ],
  "exclude": [
    ".server/**/*.ts",
    ".server/database/**/*.ts",
    "server.config.ts",
    "schema.ts",
    "api/**/*.ts",
    "**/*.tsx",
    "scratch/**/*.ts",
    "scanner/**/*.ts",
    "node_modules"
  ],
  "files": [
    ".server/client/globals.d.ts",
    ".server/client/livereload.ts",
    ".server/client/utils.ts"
  ]
}