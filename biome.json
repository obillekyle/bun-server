{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": ["**", "!.server/.cache"]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,

    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "nursery": {
        "noFloatingPromises": "error"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "useAwait": "error",
        "noExplicitAny": "off",
        "noConfusingVoidType": "off",
        "noThenProperty": "off"
      },
      "complexity": {
        "noThisInStatic": "off",

        "noExcessiveCognitiveComplexity": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded",
      "bracketSameLine": true
    }
  },
  "html": {
    "parser": {
      "interpolation": true
    }
  }
}
