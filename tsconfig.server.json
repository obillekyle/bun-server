{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["bun-types"]
  },
  "include": [
    "**/*.tsx",
    "api/**/*.ts",
    ".server/**/*.ts",
    ".server/**/*.tsx",
    "server.config.ts",
    "schema.ts",
    "package.json"
  ],
  "exclude": [
    ".server/client/**/*",
    ".server/.cache/**/*",
  ],

  "files": [".server/client/log.ts"]
}
