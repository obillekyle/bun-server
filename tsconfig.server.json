{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,

    "types": ["bun-types"],
    "paths": {
      "@server/*": ["./.server/*"],
      "@database/*": ["./.database/*"],
      "@api/*": ["./api/*"]
    }
  },
  "include": [
    ".server/**/*.ts",
    ".database/**/*.ts",
    "**/*.tsx",
    "api/**/*.ts",
    "server.config.ts",
    ".server/serve.ts"
  ],
  "exclude": [
    ".server/client.d.ts",
    ".server/client-livereload.ts",
    ".server/client-utils.ts"
  ]
}
