{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Server",
      "type": "shell",
      "command": "bun dev",
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "bun-tsc-watch",
      "type": "shell",      
      "command": "bun --bun tsc --noEmit -w --project tsconfig.server.json",
      "isBackground": true,
      "problemMatcher": {
        "base": "$tsc-watch",
        "owner": "typescript",
        "background": {
          "activeOnStart": true
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "focus": false,
        "close": false
      }
    }
  ]
}